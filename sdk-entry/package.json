{
  "name": "@steinv/publiq-entry-sdk",
  "version": "1.0.0",
  "description": "BETA OpenAPI client for Publiq Entry SDK - UitInVlaander",
  "author": "Stein Vanmassenhove",
  "repository": {
    "type": "git",
    "url": "https://github.com/steinv/ts-uitpas-sdk"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "typescript": "^4.0 || ^5.0"
  }
}
